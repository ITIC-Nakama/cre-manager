# ITIC Career Center — modèle de configuration
# cp .env.example .env puis adapter les valeurs

SERVER_PORT=8080

SECRET_KEY=change-me-use-long-random-string-min-32-chars
REFRESH_SECRET_KEY=change-me-use-another-long-random-string
TOKEN_EXPIRATION_TIME=3600000
REFRESH_TOKEN_EXPIRATION_TIME=604800000

DB_PORT=5432
DB_NAME=itic_career_center
DB_USERNAME=postgres
DB_PASSWORD=postgres

BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@itic.fr
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=ITIC

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@itic-career-center.fr

# ─── Storage Configuration ─────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_LOCAL_BASE_URL=http://localhost:8080/api/v1/files

# Cloudflare R2 / S3 settings (required if STORAGE_PROVIDER=r2)
# STORAGE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_R2_BUCKET=my-bucket-name
# STORAGE_R2_ACCESS_KEY=my-access-key-id
# STORAGE_R2_SECRET_KEY=my-secret-access-key
# STORAGE_R2_PUBLIC_URL=https://pub-some-subdomain.r2.dev
# STORAGE_R2_REGION=eu-west-3

# ─── Config Commune de Déploiement ITIC CRE ────────────────────

# ─── Backend Settings ───
SERVER_PORT=8080
SECRET_KEY=change-me-use-long-random-string-min-32-chars
REFRESH_SECRET_KEY=change-me-use-another-long-random-string
TOKEN_EXPIRATION_TIME=3600000
REFRESH_TOKEN_EXPIRATION_TIME=604800000

# ─── Database Settings ───
DB_PORT=5432
DB_NAME=itic_cre
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DDL_AUTO=update

# ─── Admin Bootstrap ───
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@itic.fr
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=ITIC

# ─── Security & Mail ───
CORS_ORIGINS=http://localhost:80,http://localhost:5173,http://localhost
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@itic-cre.fr

# ─── Local Storage ───
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_LOCAL_BASE_URL=http://localhost:8080/api/v1/files

# ─── File Upload Limits ────────────────────────────────────────
# MAX_FILE_SIZE=512MB
# UPLOAD_CONNECTION_TIMEOUT=120s
# MAX_CV_SIZE_MB=10
# MAX_IMAGE_SIZE_MB=15
# MAX_VIDEO_SIZE_MB=500

# ─── Frontend Settings (Build Time) ───
REACT_APP_API_BASE_URL=http://localhost:8080/api/v1
REACT_APP_APP_NAME="ITIC CRE"
